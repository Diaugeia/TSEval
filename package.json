{
  "name": "tseval-leaderboard",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "TS-Eval leaderboard — standalone static site (UI + data + submission pipeline). Deployed to HF Space + Cloudflare.",
  "scripts": {
    "sync:data": "mkdir -p public && cp data/visualization_data.json public/visualization_data.json",
    "leaderboard": "python3 pipeline/build_leaderboard.py",
    "dev": "bun run sync:data && next dev",
    "build": "bun run sync:data && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "next": "^15.1.6",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
